

async def test_announce(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Тестовая рассылка для проверки (только для админа)"""
    user_id = update.effective_user.id
    
    if str(user_id) != ADMIN_ID:
        await update.message.reply_text("❌ Эта команда только для организаторов")
        return
    
    await update.message.reply_text("🔍 Начинаю тестовую проверку пользователей...")
    
    try:
        # Получаем всех пользователей
        all_users = sheets_manager.get_all_users()
        
        if not all_users:
            await update.message.reply_text("❌ Нет пользователей в таблице")
            return
        
        # Формируем отчет
        report = "📊 <b>ОТЧЕТ О ПОЛЬЗОВАТЕЛЯХ</b>\n\n"
        report += f"Всего пользователей: {len(all_users)}\n\n"
        
        for i, user in enumerate(all_users, 1):
            user_id_val = user.get('user_id', 'Нет')
            user_name = user.get('full_name', 'Неизвестно')
            user_phone = user.get('phone', 'Нет')
            
            # Проверяем тип и значение
            user_id_type = type(user_id_val).__name__
            user_id_str = str(user_id_val) if user_id_val else ''
            is_valid = user_id_str.isdigit() if user_id_str else False
            
            report += f"👤 <b>{i}. {user_name}</b>\n"
            report += f"   📱 Телефон: {user_phone}\n"
            report += f"   🆔 ID: {user_id_val} (тип: {user_id_type})\n"
            report += f"   ✅ Валидный: {'Да' if is_valid else 'Нет'}\n\n"
        
        # Разбиваем отчет на части, если он слишком длинный
        if len(report) > 4000:
            # Отправляем первую часть
            await update.message.reply_text(report[:4000], parse_mode='HTML')
            # Отправляем остаток
            await update.message.reply_text(report[4000:], parse_mode='HTML')
        else:
            await update.message.reply_text(report, parse_mode='HTML')
        
        # Дополнительно выводим в консоль
        print("\n" + "="*50)
        print("ТЕСТОВЫЙ ОТЧЕТ О ПОЛЬЗОВАТЕЛЯХ")
        print("="*50)
        for i, user in enumerate(all_users, 1):
            print(f"\n{i}. {user.get('full_name', 'Неизвестно')}")
            print(f"   ID: {user.get('user_id', 'Нет')} (тип: {type(user.get('user_id')).__name__})")
            print(f"   Телефон: {user.get('phone', 'Нет')}")
        
        await update.message.reply_text("✅ Тестовая проверка завершена!")
        
    except Exception as e:
        error_msg = f"❌ Ошибка при проверке: {e}"
        print(error_msg)
        await update.message.reply_text(error_msg)


async def test_send_to_user(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Тестовая отправка конкретному пользователю (только для админа)"""
    user_id = update.effective_user.id
    
    if str(user_id) != ADMIN_ID:
        await update.message.reply_text("❌ Эта команда только для организаторов")
        return
    
    # Использование: /test_send <user_id> <сообщение>
    if len(context.args) < 2:
        await update.message.reply_text(
            "Использование: /test_send [user_id] [сообщение]\n"
            "Пример: /test_send 123456789 Привет!"
        )
        return
    
    target_user_id = context.args[0]
    message_text = " ".join(context.args[1:])
    
    try:
        await context.bot.send_message(
            chat_id=int(target_user_id),
            text=f"🧪 <b>ТЕСТОВОЕ СООБЩЕНИЕ</b>\n\n{escape_html(message_text)}",
            parse_mode='HTML'
        )
        await update.message.reply_text(f"✅ Сообщение отправлено пользователю {target_user_id}")
        print(f"✅ Тестовое сообщение отправлено {target_user_id}")
        
    except Exception as e:
        error_msg = f"❌ Ошибка отправки: {e}"
        print(error_msg)
        await update.message.reply_text(error_msg)


async def test_announce_dry_run(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Сухой запуск рассылки (только проверка, без отправки)"""
    user_id = update.effective_user.id
    
    if str(user_id) != ADMIN_ID:
        await update.message.reply_text("❌ Эта команда только для организаторов")
        return
    
    if not context.args:
        await update.message.reply_text("Использование: /test_dry [сообщение]")
        return
    
    message = " ".join(context.args)
    
    await update.message.reply_text("🔍 Выполняю сухой запуск рассылки (без отправки)...")
    
    try:
        all_users = sheets_manager.get_all_users()
        
        if not all_users:
            await update.message.reply_text("❌ Нет пользователей в таблице")
            return
        
        # Анализируем пользователей
        valid_users = []
        invalid_users = []
        
        for user in all_users:
            user_id_val = user.get('user_id', '')
            user_name = user.get('full_name', 'Неизвестно')
            
            user_id_str = str(user_id_val) if user_id_val else ''
            
            if user_id_str and user_id_str.isdigit():
                valid_users.append({
                    'id': user_id_str,
                    'name': user_name,
                    'phone': user.get('phone', 'Нет')
                })
            else:
                invalid_users.append({
                    'id': user_id_str if user_id_str else 'Пустой',
                    'name': user_name,
                    'reason': 'ID невалидный' if user_id_str else 'ID отсутствует'
                })
        
        # Формируем отчет
        report = "📊 <b>СУХОЙ ЗАПУСК РАССЫЛКИ</b>\n\n"
        report += f"📝 Сообщение: {escape_html(message[:100])}\n"
        report += f"👥 Всего пользователей: {len(all_users)}\n"
        report += f"✅ Будет отправлено: {len(valid_users)}\n"
        report += f"❌ Не будет отправлено: {len(invalid_users)}\n\n"
        
        if valid_users:
            report += "<b>✅ ПОЛУЧАТЕЛИ:</b>\n"
            for user in valid_users[:10]:  # Показываем первых 10
                report += f"   • {user['name']} (ID: {user['id']})\n"
            if len(valid_users) > 10:
                report += f"   ... и еще {len(valid_users) - 10} пользователей\n"
        
        if invalid_users:
            report += "\n<b>❌ ПРОБЛЕМНЫЕ ПОЛЬЗОВАТЕЛИ:</b>\n"
            for user in invalid_users[:10]:
                report += f"   • {user['name']} - {user['reason']}\n"
            if len(invalid_users) > 10:
                report += f"   ... и еще {len(invalid_users) - 10} пользователей\n"
        
        await update.message.reply_text(report, parse_mode='HTML')
        
        # Вывод в консоль
        print("\n" + "="*50)
        print("СУХОЙ ЗАПУСК РАССЫЛКИ")
        print("="*50)
        print(f"Сообщение: {message[:100]}")
        print(f"Всего: {len(all_users)}, Отправится: {len(valid_users)}, Проблемных: {len(invalid_users)}")
        print("\nПроблемные пользователи:")
        for user in invalid_users:
            print(f"   - {user['name']}: {user['reason']}")
        
        await update.message.reply_text("✅ Сухой запуск завершен!")
        
    except Exception as e:
        error_msg = f"❌ Ошибка: {e}"
        print(error_msg)
        await update.message.reply_text(error_msg)